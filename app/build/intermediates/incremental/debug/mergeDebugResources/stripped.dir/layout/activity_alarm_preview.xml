<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <TextView
        android:id="@+id/tvInstructions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:textColor="@color/text_label"
        android:textSize="13sp"
        android:lineSpacingExtra="3dp"
        android:text="Tap any time to correct it, then press Set All Alarms."/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="@color/navy"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView android:layout_width="44dp" android:layout_height="match_parent"
            android:text="Day" android:textColor="@color/gold" android:textStyle="bold"
            android:gravity="center_vertical" android:textSize="12sp"/>
        <TextView android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="Fajr"
            android:textColor="@color/gold" android:textStyle="bold"
            android:gravity="center" android:textSize="12sp"/>
        <TextView android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="Zuhr"
            android:textColor="@color/gold" android:textStyle="bold"
            android:gravity="center" android:textSize="12sp"/>
        <TextView android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="Asr"
            android:textColor="@color/gold" android:textStyle="bold"
            android:gravity="center" android:textSize="12sp"/>
        <TextView android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="Maghrib"
            android:textColor="@color/gold" android:textStyle="bold"
            android:gravity="center" android:textSize="12sp"/>
        <TextView android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="Isha"
            android:textColor="@color/gold" android:textStyle="bold"
            android:gravity="center" android:textSize="12sp"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/navy"
        android:padding="12dp">

        <Button
            android:id="@+id/btnCancelAlarms"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Cancel All"
            android:textSize="13sp"
            android:backgroundTint="@color/red_cancel"
            android:textColor="@color/white"/>

        <Button
            android:id="@+id/btnSetAlarms"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="2"
            android:text="Set All Alarms"
            android:textSize="14sp"
            android:backgroundTint="@color/gold"
            android:textColor="@color/bg_dark"/>
    </LinearLayout>

</LinearLayout>
